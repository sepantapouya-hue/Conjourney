# Optional — multiplayer presence (Figma-style live cursors + avatars).
# Get a free public API key at https://liveblocks.io/dashboard.
# Set this in Vercel → Settings → Environment Variables (and locally
# in .env) to turn it on. Without it, the app runs in single-player mode.
VITE_LIVEBLOCKS_PUBLIC_KEY=pk_dev_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
